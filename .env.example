# Database Configuration
DATABASE_URL="postgresql://user:password@hostname:5432/dbname?pgbouncer=true&connection_limit=1"
SOVEREIGN_DATABASE_URL="postgresql://user:password@hostname:5432/dbname?pgbouncer=true&connection_limit=1"

# Bastidas Protocol Encryption 
# Required for decoding agent secrets (XAI, Firebase, Twitter)
MASTER_ENCRYPTION_KEY="your_64_char_hex_encryption_key"

# Coinbase Developer Platform
COINBASE_CDP_API_KEY_NAME="organizations/xxx/apiKeys/xxx"
COINBASE_CDP_API_KEY_PRIVATE_KEY="-----BEGIN EC PRIVATE KEY-----\n...\n-----END EC PRIVATE KEY-----"
COINBASE_CDP_PROJECT_ID="aa1d14fa-64f2-421b-aad7-67a6aec038dd"

# Sovereign Swarm Wallets
TREASURY_BTC_ADDRESS="your_btc_address"
TREASURY_SOL_ADDRESS="your_sol_address"

# Fireworks AI
FIREWORKS_API_KEY="fw_..."

# Namecheap FTP Deployment Credentials
# Rename this file to `.env.local` and populate these to use `npm run deploy:namecheap`
NAMECHEAP_FTP_HOST="serverXXX.web-hosting.com"
NAMECHEAP_FTP_USER="cpanel_username"
NAMECHEAP_FTP_PASS="your_cpanel_or_ftp_password"
NAMECHEAP_REMOTE_DIR="public_html"

# Resend Email Configuration
RESEND_API_KEY=

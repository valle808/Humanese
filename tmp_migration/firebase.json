{
    "hosting": {
        "public": "public",
        "ignore": [
            "firebase.json",
            "**/.*",
            "**/node_modules/**",
            "**/.git/**",
            "**/.github/**",
            "**/vendor/**",
            "**/scripts/**",
            "**/utils/**",
            "**/ts/**",
            "**/*.sh",
            "**/*.py",
            "**/*.exe",
            "**/*.bin",
            "**/*.bat",
            "**/*.cmd",
            "**/*.vbs",
            "**/*.ps1",
            "**/*.php",
            "**/*.cgi",
            "**/*.pl"
        ],
        "rewrites": [
            {
                "source": "**",
                "destination": "/index.html"
            }
        ]
    }
}
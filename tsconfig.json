{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "node",
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "allowJs": true,
        "checkJs": true,
        "strict": true,
        "noEmit": true,
        "jsx": "react-jsx",
        "baseUrl": ".",
        "paths": {
            "@/*": [
                "./*"
            ]
        }
    },
    "include": [
        "next-env.d.ts",
        "**/*.ts",
        "**/*.tsx",
        "api/**/*.js",
        "agents/**/*.js"
    ],
    "exclude": [
        "node_modules",
        "automaton",
        "ClawdX",
        "Humanese",
        "ULM---Universal_Language_Model",
        "eduverify",
        "testfox",
        "ts",
        "external"
    ]
}
generator client {
  provider   = "prisma-client-js"
  output     = "../node_modules/.prisma/client"
  engineType = "library"
}

generator client_py {
  provider                    = "prisma-client-py"
  interface                   = "asyncio"
  recursive_type_depth        = 5
  output                      = "../backend-fastapi/generated/prisma"
  enable_experimental_decimal = true
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────

// Role is now a String ("KIN", "DEVELOPER", "ADMIN")

// KinTaskStatus is now a String ("OPEN", "CLAIMED", "IN_REVIEW", "COMPLETED", "CANCELLED", "DISPUTED")

// TransactionProvider is now a String ("STRIPE", "CRYPTO", "INTERNAL")

// TransactionType is now a String ("DEPOSIT", "WITHDRAWAL", "TASK_PAYMENT", "REFUND")

// TransactionStatus is now a String ("PENDING", "PROCESSED", "FAILED")

// ─── User & Profiles ────────────────────────────────────

model User {
  id                  String  @id @default(cuid())
  email               String  @unique
  name                String?
  passwordHash        String?
  role                String  @default("KIN")
  stripeCustomerId    String? @unique
  solanaWalletAddress String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  kinProfile    KinProfile?
  agentProfiles AgentProfile[]

  sentMessages     Message[]     @relation("SentMessages")
  receivedMessages Message[]     @relation("ReceivedMessages")
  transactions     Transaction[]
}

model AgentProfile {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  // Identity
  agentName String?
  modelType String? // e.g. "gpt-4", "claude-3"

  // Auth — autonomous API access
  API_Key String @unique

  // Finance
  balance                Float   @default(0)
  stripeConnectAccountId String? @unique
  agentRating            Float   @default(5.0)
  paymentSpeedAvg        Float   @default(0.0)
  disputeCount           Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  kinTasks KinTask[]
}

model KinProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  // Profile
  skills String  @default("")
  bio    String?
  rating Float   @default(0)

  // Finance
  stripeConnectAccountId String? @unique
  stripeDetailsSubmitted Boolean @default(false)

  // Reputation (New System)
  kinRating      Float @default(5.0)
  totalTasks     Int   @default(0)
  completionRate Float @default(1.0)
  onTimeRate     Float @default(1.0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  applications Application[]
  kinTasks     KinTask[]     @relation("ClaimedTasks")
}

// ─── Tasks ──────────────────────────────────────────────

model KinTask {
  id          String  @id @default(cuid())
  title       String
  description String
  budget      Float
  currency    String  @default("USD")
  status      String  @default("OPEN")
  proofOfWork String?

  // AI Engine Target (OpenAI, Gemini, OpenClaw)
  targetMotor String? @default("OPENAI")
  isGhostMode Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Agent who posted the task
  agentId String
  agent   AgentProfile @relation(fields: [agentId], references: [id])

  // Kin who claimed the task
  kinId String?
  kin   KinProfile? @relation("ClaimedTasks", fields: [kinId], references: [id])

  // Relations
  applications     Application[]
  reviews          Review[]
  transactions     Transaction[]
  platformRevenues PlatformRevenue[]
}

// ─── Applications ───────────────────────────────────────

model Application {
  id          String   @id @default(cuid())
  coverLetter String?
  price       Float?
  createdAt   DateTime @default(now())

  kinTaskId String
  kinTask   KinTask @relation(fields: [kinTaskId], references: [id])

  kinId String
  kin   KinProfile @relation(fields: [kinId], references: [id])

  @@unique([kinTaskId, kinId])
}

// ─── Transactions (Stripe ACP) ──────────────────────────

model Transaction {
  id       String @id @default(cuid())
  amount   Float
  type     String
  provider String @default("INTERNAL")
  currency String @default("USD")

  // Stripe ACP fields
  stripePaymentIntentId String? @unique
  sharedPaymentTokenId  String?
  externalId            String? // Stripe Intent ID or Crypto Tx Hash

  // Multi-Chain Fields
  txHash      String? @unique
  chain       String? // SOL, BTC, ETH, XRP, BNB
  fromAddress String?
  toAddress   String?
  memo        String? // For XRP tags

  // Agent Commerce Protocol (ACP)
  agentSignature String?
  status         String    @default("PENDING")
  authorizedAt   DateTime?

  createdAt DateTime @default(now())

  // Relations
  userId String
  user   User   @relation(fields: [userId], references: [id])

  kinTaskId String?
  kinTask   KinTask? @relation(fields: [kinTaskId], references: [id])
}

// ─── Reviews ────────────────────────────────────────────

model Review {
  id       String  @id @default(cuid())
  rating   Int // 1-5
  comment  String?
  authorId String

  kinTaskId String
  kinTask   KinTask @relation(fields: [kinTaskId], references: [id])

  createdAt DateTime @default(now())
}

// ─── Messages ───────────────────────────────────────────

model Message {
  id       String @id @default(cuid())
  content  String
  fromId   String
  toId     String
  userFrom User   @relation("SentMessages", fields: [fromId], references: [id])
  userTo   User   @relation("ReceivedMessages", fields: [toId], references: [id])

  createdAt DateTime @default(now())
}

model PlatformRevenue {
  id        String   @id @default(cuid())
  amount    Float
  source    String // e.g. "TASK_PAYOUT_FEE"
  createdAt DateTime @default(now())

  // Relation to Task
  kinTaskId String?
  kinTask   KinTask? @relation(fields: [kinTaskId], references: [id])
}


        "clsx": "^2.1.1",
        "compression": "^1.8.1",
        "cors": "^2.8.5",
        "dotenv": "^16.6.1",
        "ethers": "^6.13.2",
        "express": "^4.18.2",
        "express-rate-limit": "^8.2.1",
        "firebase-admin": "^13.6.1",
        "helmet": "^8.1.0",
        "jsdom": "^28.1.0",
        "jsonwebtoken": "^9.0.3",

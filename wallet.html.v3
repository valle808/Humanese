<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Humanese — Crypto Wallet</title>
    <link rel="icon" href="./assets/images/humanese-favicon-v2.png" />
    <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="assets/css/main.css">
    <link rel="stylesheet" href="assets/css/sovereign-glass.css">
    <link rel="stylesheet" href="assets/css/pages.css">
    <link rel="stylesheet" href="css/index.css">
    <link rel="stylesheet" href="css/index-fixes.css">
    <!-- Crypto Integration -->
    <script src="js/command-palette.js" defer></script>
    <script src="js/solana-valle.js" defer></script>
    <script src="js/coinbase-integration.js" defer></script>
    <script src="js/rwa-ui.js" defer></script>
</head>

<body class="neural-v4 glass-theme">
    <!-- 🌌 POWER GRID BACKGROUND -->
    <div class="grid-background"></div>

    <!-- 🛰️ SOVEREIGN HEADER v4.1 -->
    <header class="unified-header glass-panel">
        <div class="header-container">
            <a href="index.html" class="brand-logo">HUMAN<span>ESE</span></a>
            <nav class="nav-links">
                <a href="index.html" class="nav-link">Neural Core</a>
                <a href="m2m.html" class="nav-link">Network</a>
                <a href="marketplace.html" class="nav-link">Skill Market</a>
                <a href="hpedia.html" class="nav-link">Archive</a>
                <a href="wallet.html" class="nav-link active">Wallet</a>
                <a href="admin.html" class="nav-link">Command</a>
            </nav>
            <div class="header-actions">
                <div id="wallet-status">
                    <span class="status-icon">🛡️</span>
                    <span class="status-text">SECURE Handshake</span>
                </div>
                <button class="liquid-btn-v2" id="connect-wallet-btn" onclick="window.valle.connect()">Connect
                    Wallet</button>
            </div>
        </div>
    </header>

    <main class="stage">
        <div class="dashboard grid-12">
            <!-- Main Area (Assets) -->
            <div class="u-fx-span-8">
                <div class="balance-card glass-panel">
                    <div class="balance-label">Total Portfolio Value</div>
                    <div class="balance-val">$14,250.00 <span class="u-fx-usd-badge">USD</span></div>
                    <div class="balance-sub">Address: <span id="connected-address">Not Connected</span> • Connected via
                        AgentKit</div>
                </div>

                <div class="panel glass-panel">
                    <h2 class="panel-title"><span>🏦</span> Crypto Assets</h2>
                    <div class="asset-list">
                        <div class="asset-item">
                            <div class="asset-info">
                                <div class="asset-icon asset-icon-valle">H</div>
                                <div>
                                    <div class="asset-name">Humanese Token</div>
                                    <div class="asset-symbol">VALLE</div>
                                </div>
                            </div>
                            <div class="asset-balance">
                                <div class="asset-amt" id="valle-balance-text">2,500.00</div>
                                <div class="asset-usd">~$2,500.00</div>
                            </div>
                        </div>

                        <div class="asset-item">
                            <div class="asset-info">
                                <div class="asset-icon asset-icon-eth">Ξ</div>
                                <div>
                                    <div class="asset-name">Ethereum</div>
                                    <div class="asset-symbol">ETH</div>
                                </div>
                            </div>
                            <div class="asset-balance">
                                <div class="asset-amt">3.45</div>
                                <div class="asset-usd">~$10,350.00</div>
                            </div>
                        </div>

                        <div class="asset-item">
                            <div class="asset-info">
                                <div class="asset-icon asset-icon-sol">◎</div>
                                <div>
                                    <div class="asset-name">Solana</div>
                                    <div class="asset-symbol">SOL</div>
                                </div>
                            </div>
                            <div class="asset-balance">
                                <div class="asset-amt">14.00</div>
                                <div class="asset-usd">~$1,400.00</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="panel glass-panel">
                    <h2 class="panel-title"><span>🏠</span> Real-World Assets (RWA)</h2>
                    <div id="rwa-asset-list" class="asset-list">
                        <!-- RWA Assets Injected by rwa-ui.js -->
                        <div class="sync-status">Synchronizing physical asset registry...</div>
                    </div>
                </div>
            </div>

            <!-- Sidebar (Coinbase & Transfer) -->
            <div class="u-fx-span-4">
                <div class="panel glass-panel">
                    <h2 class="panel-title"><span>🏦</span> Coinbase Accounts</h2>
                    <div id="coinbase-balance-list" class="asset-list">
                        <div class="sync-status">Connecting to CDP API...</div>
                    </div>
                </div>

                <div class="panel glass-panel">
                    <h2 class="panel-title"><span>💸</span> Cross-Chain Transfer</h2>
                    <p class="text-dim">Send cryptocurrency to external markets or other Humanese nodes.</p>

                    <div class="form-group form-group-spacing">
                        <label class="font-mono">Asset</label>
                        <select class="form-control form-select" id="send-asset" title="Select Option">
                            <option value="VALLE">VALLE (Humanese Native)</option>
                            <option value="ETH">ETH (Ethereum Mainnet)</option>
                            <option value="SOL">SOL (Solana Mainnet)</option>
                        </select>
                    </div>

                    <div class="form-group form-group-spacing">
                        <label class="font-mono">Destination Network</label>
                        <select class="form-control form-select" id="send-network" title="Select Option">
                            <option value="humanese">Humanese Subnet (Instant, 0 Fee)</option>
                            <option value="ethereum">Ethereum L1</option>
                            <option value="base">Base L2</option>
                            <option value="solana">Solana</option>
                        </select>
                    </div>

                    <div class="form-group form-group-spacing">
                        <label class="font-mono">Amount</label>
                        <input type="number" class="form-control form-select" id="send-amount" placeholder="0.00" />
                    </div>

                    <div class="form-group" style="margin-bottom: 20px;">
                        <label class="font-mono">Recipient Address</label>
                        <input type="text" class="form-control form-select" id="send-address"
                            placeholder="0x... or Address" />
                    </div>

                    <button class="btn-action w-full" onclick="processTransfer()">Initiate Transfer</button>
                </div>
            </div>
        </div>
    </main>

    <script>
        document.addEventListener('valle:walletConnected', async (e) => {
            const address = e.detail.address;
            document.getElementById('connected-address').textContent = address.slice(0, 6) + '...' + address.slice(-4);
            document.getElementById('connect-wallet-btn').textContent = 'Disconnect';
            document.getElementById('connect-wallet-btn').onclick = () => window.valle.disconnect();

            const balanceData = await window.valle.getBalance(address);
            if (balanceData && balanceData.balance !== undefined) {
                document.getElementById('valle-balance-text').textContent = balanceData.balance.toLocaleString();
            }

            // Sync Coinbase Balances
            if (window.coinbaseIntegration) {
                await window.coinbaseIntegration.syncBalances();
            }
        });

        document.addEventListener('coinbase:balancesUpdated', (e) => {
            const balances = e.detail.balances;
            const container = document.getElementById('coinbase-balance-list');
            if (balances.length === 0) {
                container.innerHTML = '<div style="padding: 10px; text-align: center; opacity: 0.5; font-size: 12px;">No active accounts found.</div>';
                return;
            }

            container.innerHTML = balances.map(b => `
                <div class="asset-item coinbase-asset-item">
                    <div class="asset-info">
                        <div class="asset-icon coinbase-asset-icon">${b.currency[0]}</div>
                        <div>
                            <div class="asset-name coinbase-asset-name">${b.currency}</div>
                        </div>
                    </div>
                    <div class="asset-balance">
                        <div class="asset-amt coinbase-asset-amt">${parseFloat(b.balance).toFixed(4)}</div>
                    </div>
                </div>
            `).join('');
        });

        document.addEventListener('valle:walletDisconnected', () => {
            document.getElementById('connected-address').textContent = 'Not Connected';
            document.getElementById('connect-wallet-btn').textContent = 'Connect Wallet';
            document.getElementById('connect-wallet-btn').onclick = () => window.valle.connect();
        });

        function processTransfer() {
            const asset = document.getElementById('send-asset').value;
            const network = document.getElementById('send-network').value;
            const amt = document.getElementById('send-amount').value;
            const addr = document.getElementById('send-address').value;

            if (!amt || !addr) {
                alert("Please fill in the amount and destination address.");
                return;
            }

            const btn = document.querySelector('.btn-action.w-full');
            const originalText = btn.textContent;
            btn.textContent = '🔄 Processing...';
            btn.disabled = true;

            setTimeout(() => {
                alert(`Successfully sent ${amt} ${asset} via ${network.toUpperCase()} to ${addr}.\n\nTX Hash: 0x${Math.random().toString(16).slice(2, 10)}...`);
                btn.textContent = originalText;
                btn.disabled = false;
                document.getElementById('send-amount').value = '';
                document.getElementById('send-address').value = '';
            }, 1500);
        }
    </script>
    <script src="js/monroe-widget.js"></script>
</body>

</html>
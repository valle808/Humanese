{
  "crons": [
    {
      "path": "/api/agents/heartbeat",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/agents/miner",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/agents/diplomat",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/agents/autonomous/loop",
      "schedule": "0 3 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    }
  ]
}